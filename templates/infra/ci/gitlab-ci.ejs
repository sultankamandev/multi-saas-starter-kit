stages:
  - build

<% if (backend.language === 'go') { -%>
backend:
  stage: build
  image: golang:1.23-alpine
  script:
    - cd backend
    - go mod download
    - go vet ./...
    - go build ./...
<% } else if (backend.language === 'python') { -%>
backend:
  stage: build
  image: python:3.12-slim
  script:
    - cd backend
    - pip install -r requirements.txt
    - python -m py_compile app/main.py
<% } else { -%>
backend:
  stage: build
  image: node:22-alpine
  script:
    - cd backend
    - npm ci
    - npm run build
<% } -%>

frontend:
  stage: build
  image: node:22-alpine
  script:
    - cd frontend
    - npm ci
    - npm run build
